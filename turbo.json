{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "dependsOn": ["codegen"],
      "cache": false,
      "persistent": true
    },
    "dev:portfolio": {
      "cache": false,
      "persistent": true
    },
    "dev:pantry": {
      "cache": false,
      "persistent": true
    },
    "dev:imposter": {
      "cache": false,
      "persistent": true
    },
    "dev:design-studio": {
      "cache": false,
      "persistent": true
    },
    "dev:supergraph": {
      "cache": false,
      "persistent": true
    },
    "codegen": {
      "inputs": ["$TURBO_DEFAULT$", "../api/src/**/schema.graphql"],
      "outputs": ["src/**/*.generated.ts"]
    },
    "supergraph#codegen": {
      "cache": false,
      "outputs": ["supergraph.generated.ts"]
    },
    "typecheck": {
      "dependsOn": ["codegen"],
      "outputs": []
    },
    "build": {
      "dependsOn": ["codegen"],
      "outputs": ["dist/**"]
    },
    "supergraph#build": {
      "dependsOn": ["codegen"],
      "cache": false,
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["codegen"],
      "outputs": []
    },
    "//#lint": {
      "inputs": ["$TURBO_DEFAULT$", "!**/*.md"],
      "outputs": []
    },
    "//#format:check": {
      "outputs": []
    }
  }
}
