# All three point at the composed supergraph endpoint, not each service's
# own subgraph route - the supergraph exposes every subgraph's fields under
# one schema, so routing straight to a subgraph here would bypass the
# gateway federation is supposed to sit in front of.
VITE_GRAPHQL_ENDPOINT=https://api.test.petertran.au/graphql
VITE_IMPOSTER_GRAPHQL_ENDPOINT=https://api.test.petertran.au/graphql
VITE_PANTRY_GRAPHQL_ENDPOINT=https://api.test.petertran.au/graphql
