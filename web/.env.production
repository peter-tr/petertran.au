# All three point at the composed supergraph endpoint, not each service's
# own subgraph route - see web/.env.test's matching comment. build-and-
# deploy.yml now runs prerender *after* "Deploy infrastructure" (see its
# "Prerender web" step), so /graphql is guaranteed to already exist by the
# time this is read - no more bootstrap ordering concern.
VITE_GRAPHQL_ENDPOINT=https://api.petertran.au/graphql
VITE_IMPOSTER_GRAPHQL_ENDPOINT=https://api.petertran.au/graphql
VITE_PANTRY_GRAPHQL_ENDPOINT=https://api.petertran.au/graphql
VITE_DESIGN_STUDIO_GRAPHQL_ENDPOINT=https://api.petertran.au/graphql
VITE_WARM_SCHEDULE_ENDPOINT=https://api.petertran.au/warm-schedule
VITE_RUM_APP_MONITOR_ID=fe7b181c-ff4b-4bf2-8c00-6d92b21d72ca
VITE_RUM_IDENTITY_POOL_ID=ap-southeast-2:0cf3a2c0-e76e-436a-a262-28881f2b59ba
