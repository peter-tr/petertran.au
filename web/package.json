{
  "name": "web",
  "private": true,
  "version": "1.0.2",
  "type": "module",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "dev": "vite",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build && npm run prerender",
    "build:test": "tsc -b && vite build --mode test && npm run prerender",
    "prerender": "tsx scripts/prerender.tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "@graphiql/plugin-doc-explorer": "^0.4.2",
    "@graphiql/plugin-explorer": "^5.1.3",
    "@graphiql/plugin-history": "^0.4.2",
    "@graphiql/react": "^0.37.7",
    "@graphiql/toolkit": "^0.12.1",
    "@microsoft/clarity": "^1.0.2",
    "aws-rum-web": "^3.1.0",
    "graphiql": "^5.2.4",
    "graphql": "^16.14.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.7.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.2.0",
    "@graphql-codegen/typescript": "^6.1.0",
    "@graphql-codegen/typescript-operations": "^6.1.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
