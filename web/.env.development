# All four point at the local supergraph gateway (npm run dev:supergraph,
# see api/src/supergraph/dev/dev-server.ts), not each subgraph dev server's
# own port directly - see web/.env.production's matching comment. The
# gateway composes portfolio (4000), imposter (4001), pantry (4002), and
# design-studio (4004) behind one endpoint, same shape as prod/test.
VITE_GRAPHQL_ENDPOINT=http://localhost:4003/
VITE_PANTRY_GRAPHQL_ENDPOINT=http://localhost:4003/
VITE_IMPOSTER_GRAPHQL_ENDPOINT=http://localhost:4003/
VITE_DESIGN_STUDIO_GRAPHQL_ENDPOINT=http://localhost:4003/
